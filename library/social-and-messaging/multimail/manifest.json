{
  "manifest_version": "0.3",
  "name": "multimail-pp-mcp",
  "display_name": "Multimail",
  "version": "4.2.0",
  "description": "Multimail API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/multimail-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/multimail-pp-mcp",
      "args": [],
      "env": {
        "MULTIMAIL_BEARER_AUTH": "${user_config.multimail_bearer_auth}"
      }
    }
  },
  "user_config": {
    "multimail_bearer_auth": {
      "type": "string",
      "title": "MULTIMAIL_BEARER_AUTH",
      "description": "Sets MULTIMAIL_BEARER_AUTH for the Multimail MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
