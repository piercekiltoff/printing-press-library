            "token"
          ]
        },
        {
          "name": "user-key",
          "wire_name": "user",
          "type": "string",
          "location": "body",
          "description": "User key to enable",
          "required": true,
          "aliases": [
            "user"
          ]
        },
        {
          "name": "device",
          "type": "string",
          "location": "body",
          "description": "Optional device restriction"
        }
      ]
    },
    {
      "name": "groups_get",
      "description": "Get a delivery group's name and users. Required: group-key, app-token. Returns the GroupInfoResponse.",
      "method": "GET",
      "path": "/1/groups/{group_key}.json",
      "no_auth": true,
      "params": [
        {
          "name": "group-key",
          "wire_name": "group_key",
          "type": "string",
          "location": "path",
          "description": "Delivery group key",
          "required": true
        },
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "query",
          "description": "Application API token",
          "required": true,
          "aliases": [
            "token"
          ]
        }
      ]
    },
    {
      "name": "groups_list",
