          "required": true
        },
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "body",
          "description": "Application API token",
          "required": true,
          "aliases": [
            "token"
          ]
        },
        {
          "name": "user-key",
          "wire_name": "user",
          "type": "string",
          "location": "body",
          "description": "User key to remove",
          "required": true,
          "aliases": [
            "user"
          ]
        },
        {
          "name": "device",
          "type": "string",
          "location": "body",
          "description": "Optional device restriction"
        }
      ]
    },
    {
      "name": "groups_rename",
      "description": "Rename a delivery group. Required: group-key, app-token, name. Returns the new StatusResponse.",
      "method": "POST",
      "path": "/1/groups/{group_key}/rename.json",
      "no_auth": true,
      "params": [
        {
          "name": "group-key",
          "wire_name": "group_key",
          "type": "string",
          "location": "path",
          "description": "Delivery group key",
          "required": true
        },
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "body",
          "description": "Application API token",
          "required": true,
          "aliases": [
            "token"
          ]
        },
        {
          "name": "name",
          "type": "string",
          "location": "body",
          "description": "New group name",
          "required": true
        }
      ]
    },
    {
      "name": "licenses_assign",
      "description": "Assign a pre-paid license credit to a user or email. Required: app-token. Optional: user-key, email, os. Returns the new LicenseResponse.",
      "method": "POST",
      "path": "/1/licenses/assign.json",
      "no_auth": true,
      "params": [
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "body",
          "description": "Application API token with purchased license credits",
          "required": true,
          "aliases": [
            "token"
          ]
        },
        {
          "name": "user-key",
          "wire_name": "user",
          "type": "string",
          "location": "body",
          "description": "Pushover user key; required unless email is supplied",
          "aliases": [
            "user"
          ]
        },
        {
          "name": "email",
          "type": "string",
          "location": "body",
          "description": "Email address; required unless user-key is supplied"
        },
        {
          "name": "os",
          "type": "string",
          "location": "body",
          "description": "Optional platform: Android, iOS, or Desktop"
        }
      ]
    },
    {
      "name": "licenses_credits",
      "description": "Check remaining license credits. Required: app-token. Returns the LicenseResponse.",
      "method": "GET",
