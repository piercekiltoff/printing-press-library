          ]
        },
        {
          "name": "device-id",
          "wire_name": "device_id",
          "type": "string",
          "location": "query",
          "description": "Open Client device id",
          "required": true
        }
      ]
    },
    {
      "name": "messages_send",
      "description": "Send a Pushover notification. Required: app-token, user-key, message. Optional: title, device, html (plus 14 more). Returns the new MessageSendResponse.",
      "method": "POST",
      "path": "/1/messages.json",
      "no_auth": true,
      "params": [
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "body",
          "description": "Application API token; may be read from PUSHOVER_APP_TOKEN",
          "required": true,
          "aliases": [
            "token"
          ]
        },
        {
          "name": "user-key",
          "wire_name": "user",
          "type": "string",
          "location": "body",
          "description": "Recipient user, group, or subscribed user key; may be read from PUSHOVER_USER_KEY",
          "required": true,
          "aliases": [
            "user"
          ]
        },
        {
          "name": "message",
          "type": "string",
          "location": "body",
          "description": "Notification body text",
          "required": true
        },
        {
          "name": "title",
          "type": "string",
          "location": "body",
          "description": "Notification title; defaults to the application name when omitted"
        },
        {
          "name": "device",
          "type": "string",
          "location": "body",
          "description": "Device name or comma-separated device names for single-user sends"
        },
        {
          "name": "html",
          "type": "bool",
          "location": "body",
          "description": "Enable supported HTML formatting"
        },
        {
          "name": "monospace",
          "type": "bool",
          "location": "body",
          "description": "Display message in monospace formatting"
        },
        {
          "name": "priority",
          "type": "int",
          "location": "body",
          "description": "Message priority: -2 lowest, -1 low, 0 normal, 1 high, 2 emergency"
        },
        {
          "name": "sound",
          "type": "string",
          "location": "body",
          "description": "Notification sound name"
        },
        {
          "name": "timestamp",
          "type": "int",
          "location": "body",
          "description": "Unix timestamp to display as the message time"
        },
        {
          "name": "ttl",
          "type": "int",
          "location": "body",
          "description": "Seconds before the message is automatically deleted from devices"
        },
        {
          "name": "url",
          "type": "string",
          "location": "body",
          "description": "Supplementary URL shown with the message"
        },
        {
          "name": "url-title",
          "wire_name": "url_title",
          "type": "string",
          "location": "body",
          "description": "Title for the supplementary URL"
        },
        {
          "name": "attachment-base64",
          "wire_name": "attachment_base64",
          "type": "string",
          "location": "body",
          "description": "Base64-encoded image attachment"
        },
        {
          "name": "attachment-type",
          "wire_name": "attachment_type",
          "type": "string",
          "location": "body",
          "description": "MIME type for attachment-base64"
        },
        {
          "name": "encrypted",
          "type": "bool",
          "location": "body",
          "description": "Set when encrypted message fields are supplied"
        },
        {
          "name": "retry",
          "type": "int",
          "location": "body",
          "description": "Emergency priority retry interval in seconds; minimum 30"
        },
        {
          "name": "expire",
          "type": "int",
          "location": "body",
          "description": "Emergency priority retry duration in seconds; maximum 10800"
        },
        {
          "name": "callback",
          "type": "string",
          "location": "body",
          "description": "Public callback URL for emergency acknowledgement callbacks"
        },
        {
          "name": "tags",
          "type": "string",
          "location": "body",
          "description": "Comma-separated tags for emergency receipt cancellation"
        }
      ]
    },
    {
      "name": "receipts_cancel",
