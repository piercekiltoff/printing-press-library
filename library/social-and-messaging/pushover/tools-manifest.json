{
  "api_name": "pushover",
  "base_url": "https://api.pushover.net",
  "description": "Pushover Message, Receipts, Groups, Glances, Subscriptions, Teams, Licensing, and Open Client APIs.",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "none"
  },
  "required_headers": [],
  "tools": [
    {
      "name": "apps_limits",
      "description": "Check monthly message limit, remaining sends, and reset time. Required: app-token. Returns the AppLimitsResponse.",
      "method": "GET",
      "path": "/1/apps/limits.json",
      "no_auth": true,
      "params": [
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "query",
          "description": "Application API token",
          "required": true,
          "aliases": [
            "token"
          ]
        }
      ]
    },
    {
      "name": "devices_create",
      "description": "Register a new Open Client desktop device. Required: client-secret, name. Optional: os (default: O). Returns the new DeviceCreateResponse.",
      "method": "POST",
      "path": "/1/devices.json",
      "no_auth": true,
      "params": [
        {
          "name": "client-secret",
          "wire_name": "secret",
          "type": "string",
          "location": "body",
          "description": "Open Client session secret",
          "required": true,
          "aliases": [
            "secret"
          ]
        },
        {
          "name": "name",
          "type": "string",
          "location": "body",
          "description": "Short device name; alphanumeric, underscore, or dash",
          "required": true
        },
        {
          "name": "os",
          "type": "string",
          "location": "body",
          "description": "Open Client operating system marker; use capital O"
        }
      ]
    },
    {
      "name": "devices_delete-through",
      "description": "Delete downloaded Open Client messages up to a highest message id. Required: device-id, client-secret, message-id. Returns the new StatusResponse.",
      "method": "POST",
      "path": "/1/devices/{device_id}/update_highest_message.json",
      "no_auth": true,
      "params": [
        {
          "name": "device-id",
          "wire_name": "device_id",
          "type": "string",
          "location": "path",
          "description": "Open Client device id",
          "required": true
        },
        {
          "name": "client-secret",
          "wire_name": "secret",
          "type": "string",
          "location": "body",
          "description": "Open Client session secret",
          "required": true,
          "aliases": [
            "secret"
          ]
        },
        {
          "name": "message-id",
          "wire_name": "message",
          "type": "string",
          "location": "body",
          "description": "Highest downloaded message id to delete through",
          "required": true,
          "aliases": [
            "message"
          ]
        }
      ]
    },
    {
      "name": "glances_update",
      "description": "Update Glances widget fields. Required: app-token, user-key. Optional: device, title, text (plus 3 more). Returns the new StatusResponse.",
      "method": "POST",
      "path": "/1/glances.json",
      "no_auth": true,
      "params": [
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "body",
          "description": "Application API token",
          "required": true,
          "aliases": [
            "token"
          ]
        },
        {
          "name": "user-key",
          "wire_name": "user",
          "type": "string",
          "location": "body",
          "description": "Recipient user key",
          "required": true,
          "aliases": [
            "user"
          ]
        },
        {
          "name": "device",
          "type": "string",
          "location": "body",
          "description": "Optional device/widget restriction"
        },
        {
          "name": "title",
          "type": "string",
          "location": "body",
          "description": "Short field label, up to 100 characters"
        },
        {
          "name": "text",
          "type": "string",
          "location": "body",
          "description": "Main text field, up to 100 characters"
        },
        {
          "name": "subtext",
          "type": "string",
          "location": "body",
          "description": "Secondary text field, up to 100 characters"
        },
        {
          "name": "count",
          "type": "int",
          "location": "body",
          "description": "Integer count value"
        },
        {
          "name": "percent",
          "type": "int",
          "location": "body",
          "description": "Integer progress value from 0 to 100"
        }
      ]
    },
    {
      "name": "groups_add-user",
      "description": "Add a user to a delivery group. Required: group-key, app-token, user-key. Optional: device, memo. Returns the new StatusResponse.",
      "method": "POST",
      "path": "/1/groups/{group_key}/add_user.json",
      "no_auth": true,
      "params": [
        {
          "name": "group-key",
          "wire_name": "group_key",
          "type": "string",
          "location": "path",
          "description": "Delivery group key",
          "required": true
        },
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "body",
          "description": "Application API token",
          "required": true,
          "aliases": [
            "token"
          ]
        },
        {
          "name": "user-key",
          "wire_name": "user",
          "type": "string",
          "location": "body",
          "description": "User key to add",
          "required": true,
          "aliases": [
            "user"
          ]
        },
        {
          "name": "device",
          "type": "string",
          "location": "body",
          "description": "Optional device restriction"
        },
        {
          "name": "memo",
          "type": "string",
          "location": "body",
          "description": "Free-text memo for the group member"
        }
      ]
    },
    {
      "name": "groups_create",
      "description": "Create a delivery group. Required: app-token, name. Returns the new GroupCreateResponse.",
      "method": "POST",
      "path": "/1/groups.json",
      "no_auth": true,
      "params": [
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "body",
          "description": "Application API token",
          "required": true,
          "aliases": [
            "token"
          ]
        },
        {
          "name": "name",
          "type": "string",
          "location": "body",
          "description": "Group name",
          "required": true
        }
      ]
    },
    {
      "name": "groups_disable-user",
      "description": "Temporarily disable a group user. Required: group-key, app-token, user-key. Optional: device. Returns the new StatusResponse.",
      "method": "POST",
      "path": "/1/groups/{group_key}/disable_user.json",
      "no_auth": true,
      "params": [
        {
          "name": "group-key",
          "wire_name": "group_key",
          "type": "string",
          "location": "path",
          "description": "Delivery group key",
          "required": true
        },
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "body",
          "description": "Application API token",
          "required": true,
          "aliases": [
            "token"
          ]
        },
        {
          "name": "user-key",
          "wire_name": "user",
          "type": "string",
          "location": "body",
          "description": "User key to disable",
          "required": true,
          "aliases": [
            "user"
          ]
        },
        {
          "name": "device",
          "type": "string",
          "location": "body",
          "description": "Optional device restriction"
        }
      ]
    },
    {
      "name": "groups_enable-user",
      "description": "Re-enable a disabled group user. Required: group-key, app-token, user-key. Optional: device. Returns the new StatusResponse.",
      "method": "POST",
      "path": "/1/groups/{group_key}/enable_user.json",
      "no_auth": true,
      "params": [
        {
          "name": "group-key",
          "wire_name": "group_key",
          "type": "string",
          "location": "path",
          "description": "Delivery group key",
