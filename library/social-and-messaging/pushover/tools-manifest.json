    {
      "name": "groups_remove-user",
      "description": "Remove a user from a delivery group. Required: group-key, app-token, user-key. Optional: device. Returns the new StatusResponse.",
      "method": "POST",
      "path": "/1/groups/{group_key}/remove_user.json",
      "no_auth": true,
      "params": [
        {
          "name": "group-key",
          "wire_name": "group_key",
          "type": "string",
          "location": "path",
