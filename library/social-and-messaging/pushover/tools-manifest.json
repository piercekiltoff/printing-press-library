      "params": [
        {
          "name": "app-token",
          "wire_name": "token",
          "type": "string",
          "location": "query",
          "description": "Application API token",
          "required": true,
          "aliases": [
            "token"
          ]
        }
      ]
    },
    {
      "name": "messages_download",
      "description": "Download pending messages for an Open Client device. Required: client-secret, device-id. Returns the ClientMessagesResponse.",
      "method": "GET",
      "path": "/1/messages.json",
      "no_auth": true,
      "params": [
        {
          "name": "client-secret",
          "wire_name": "secret",
          "type": "string",
          "location": "query",
