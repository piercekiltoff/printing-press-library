{
  "api_name": "dominos",
  "base_url": "https://order.dominos.com",
  "description": "Domino's Pizza CLI - order pizza, browse menus, track orders, and manage rewards from the terminal",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "format": "Bearer {DOMINOS_TOKEN}",
    "in": "header",
    "env_vars": [
      "DOMINOS_TOKEN"
    ]
  },
  "required_headers": [],
  "tools": [
    {
      "name": "auth_login",
      "description": "Log in to a Domino's account",
      "method": "POST",
      "path": "/power/login",
      "params": [
        {
          "name": "u",
          "type": "string",
          "location": "body",
          "description": "Username (email)",
          "required": true
        },
        {
          "name": "p",
          "type": "string",
          "location": "body",
          "description": "Password",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_categories",
      "description": "Get menu categories for a store",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_create_cart",
      "description": "Create a new shopping cart",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_customer",
      "description": "Get authenticated customer profile with saved addresses and preferences",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_deals_list",
      "description": "Get available deals and coupons for a store",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_get_cart",
      "description": "Get cart by ID with items and pricing",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_loyalty_deals",
      "description": "Get member-exclusive deals",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_loyalty_points",
      "description": "Get loyalty points balance and status",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_loyalty_rewards",
      "description": "Get available loyalty rewards by tier",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_products",
      "description": "Get products in a category with customization options",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_quick_add_product",
      "description": "Quick-add a product to cart by code",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "graphql_summary_charges",
      "description": "Get cart totals including tax and delivery fee",
      "method": "POST",
      "path": "/api/web-bff/graphql",
      "params": [
        {
          "name": "operationName",
          "type": "string",
          "location": "body",
          "description": "GraphQL operation name",
          "required": true
        }
      ]
    },
    {
      "name": "menu_get_menu",
      "description": "Get the full menu for a store with categories, products, variants, and toppings",
      "method": "GET",
      "path": "/power/store/{storeID}/menu",
      "params": [
        {
          "name": "storeID",
          "type": "string",
          "location": "path",
          "description": "Store ID number",
          "required": true
        },
        {
          "name": "lang",
          "type": "string",
          "location": "query",
          "description": "Language code"
        },
        {
          "name": "structured",
          "type": "boolean",
          "location": "query",
          "description": "Return structured menu hierarchy"
        }
      ]
    },
    {
      "name": "orders_place_order",
      "description": "Place an order for delivery or carryout",
      "method": "POST",
      "path": "/power/place-order",
      "params": [
        {
          "name": "Order",
          "type": "object",
          "location": "body",
          "description": "Validated and priced order object with payment",
          "required": true
        }
      ]
    },
    {
      "name": "orders_price_order",
      "description": "Get the price for an order including taxes and fees",
      "method": "POST",
      "path": "/power/price-order",
      "params": [
        {
          "name": "Order",
          "type": "object",
          "location": "body",
          "description": "Complete order object (same as validate)",
          "required": true
        }
      ]
    },
    {
      "name": "orders_validate_order",
      "description": "Validate an order before placing it",
      "method": "POST",
      "path": "/power/validate-order",
      "params": [
        {
          "name": "Order",
          "type": "object",
          "location": "body",
          "description": "Complete order object",
          "required": true
        }
      ]
    },
    {
      "name": "stores_find_stores",
      "description": "Find nearby Domino's stores by address",
      "method": "GET",
      "path": "/power/store-locator",
      "params": [
        {
          "name": "s",
          "type": "string",
          "location": "query",
          "description": "Street address",
          "required": true
        },
        {
          "name": "c",
          "type": "string",
          "location": "query",
          "description": "City, state, zip",
          "required": true
        },
        {
          "name": "type",
          "type": "string",
          "location": "query",
          "description": "Service type: Delivery, Carryout, or DriveUpCarryout"
        }
      ]
    },
    {
      "name": "stores_get_store",
      "description": "Get detailed store information including hours, capabilities, and wait times",
      "method": "GET",
      "path": "/power/store/{storeID}/profile",
      "params": [
        {
          "name": "storeID",
          "type": "string",
          "location": "path",
          "description": "Store ID number",
          "required": true
        }
      ]
    },
    {
      "name": "tracking_track_order",
      "description": "Track an order by phone number",
      "method": "GET",
      "path": "/power/tracker",
      "params": [
        {
          "name": "Phone",
          "type": "string",
          "location": "query",
          "description": "Phone number associated with the order",
          "required": true
        }
      ]
    }
  ]
}
