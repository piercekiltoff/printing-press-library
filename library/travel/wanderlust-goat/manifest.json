{
  "manifest_version": "0.3",
  "name": "wanderlust-goat-pp-mcp",
  "display_name": "Wanderlust GOAT",
  "version": "4.0.1",
  "description": "Persona-shaped place discovery within walking distance — two-stage funnel that seeds from Google Places and deep-researches each candidate against locale-specific sources.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/wanderlust-goat-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/wanderlust-goat-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
