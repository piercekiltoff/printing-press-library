{
  "api_name": "openfda",
  "base_url": "https://api.fda.gov",
  "description": "The FDA safety data terminal. Every drug adverse event, device recall, food contamination, and product label the FDA publishes — synced locally, searchable offline, with trend analysis no other tool offers.\n",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "api_key",
    "header": "api_key",
    "in": "query",
    "env_vars": [
      "FDA_API_KEY"
    ],
    "env_var_specs": [
      {
        "name": "FDA_API_KEY",
        "kind": "per_call",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ]
  },
  "required_headers": [],
  "tools": [
    {
      "name": "animal-events_list",
      "description": "Search animal adverse event reports. Optional: animal, breed, drug.",
      "method": "GET",
      "path": "/animalandveterinary/event.json",
      "params": [
        {
          "name": "animal",
          "type": "string",
          "location": "query",
          "description": "Animal species"
        },
        {
          "name": "breed",
          "type": "string",
          "location": "query",
          "description": "Animal breed"
        },
        {
          "name": "drug",
          "type": "string",
          "location": "query",
          "description": "Drug name"
        }
      ]
    },
    {
      "name": "device-510k_list",
      "description": "Search 510(k) clearance records. Optional: device, applicant, code (plus 3 more).",
      "method": "GET",
      "path": "/device/510k.json",
      "params": [
        {
          "name": "device",
          "wire_name": "device_name",
          "type": "string",
          "location": "query",
          "description": "Device name"
        },
        {
          "name": "applicant",
          "type": "string",
          "location": "query",
          "description": "Applicant/company name"
        },
        {
          "name": "code",
          "wire_name": "product_code",
          "type": "string",
          "location": "query",
          "description": "Product code"
        },
        {
          "name": "type",
          "wire_name": "clearance_type",
          "type": "string",
          "location": "query",
          "description": "Clearance type (Traditional, Special, Abbreviated)"
        },
        {
          "name": "from",
          "wire_name": "decision_date_from",
          "type": "date_range_start",
          "location": "query",
          "description": "Start of decision date range (YYYYMMDD)"
        },
        {
          "name": "to",
          "wire_name": "decision_date_to",
          "type": "date_range_end",
          "location": "query",
          "description": "End of decision date range (YYYYMMDD)"
        }
      ]
    },
    {
      "name": "device-classification_list",
      "description": "Search device classifications. Optional: device, class, specialty (plus 2 more).",
      "method": "GET",
      "path": "/device/classification.json",
