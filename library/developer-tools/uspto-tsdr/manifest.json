{
  "manifest_version": "0.3",
  "name": "uspto-tsdr-pp-mcp",
  "display_name": "Tsdr",
  "version": "4.2.0",
  "description": "Tsdr API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/uspto-tsdr-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/uspto-tsdr-pp-mcp",
      "args": [],
      "env": {
        "TSDR_APIKEY_HEADER": "${user_config.tsdr_apikey_header}"
      }
    }
  },
  "user_config": {
    "tsdr_apikey_header": {
      "type": "string",
      "title": "TSDR_APIKEY_HEADER",
      "description": "Sets TSDR_APIKEY_HEADER for the Tsdr MCP server. Get a credential from https://account.uspto.gov/api-manager.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
