{"data":{"workspace":[{"score":464.19632,"normalizedScore":25.745636446386825,"document":{"watcherCount":476,"apiCount":0,"forkCount":0,"createdAt":"2021-03-09T20:39:14","publisherHandle":"stripedev","reqSendCountExclCreator":6383,"isstale":"false","id":"dc426c90-799a-452c-a261-7f9925e005d1","slug":"stripe-developers","updatedAt":"2024-03-26T20:44:14","updatedBy":"665823","entityType":"workspace","visibilityStatus":"public","squadId":"","tags":["FEATURED"],"isFSLinked":false,"forkLabel":"","publisherName":"Stripe Developer APIs","name":"Stripe Developers","dependencyCount":6,"collectionCount":4,"lastActivityTime":"2026-04-29T16:03:20","warehouse__updated_at":"2026-04-30T01:00:00.000Z","privateNetworkFolders":[],"nameRaw":"Stripe Developers","reqSenderCountExclCreator":767,"isPublisherVerified":true,"publisherType":"team","curatedInList":[],"creatorId":"665823","description":"Overview\nThis workspace includes versioned collections of the Stripe API for you to try out with the API keys from your own Stripe account.\nBefore you start trying out our APIs, remember to sign up for a Stripe account and grab your test API keys to authenticate your requets.\nAPI Changes\nTo keep track of major Stripe API updates and version, reference the API upgrades page in our documentation. For a detailed list of API changes, please refer to our API Changelog.\nIf you need to report a bug or request an update, feel free to open an issue on our GitHub repository.","publisherId":"1604639","publisherLogo":"https://res.cloudinary.com/postman/image/upload/t_team_logo/v1629873674/team/1ac862f7c8f1a3c91a17eb66e55f748d609f653c4d2bf43d9b12adef8568555c","isPublic":true,"categories":[],"views":207221,"summary":"This workspace includes versioned collections of the Stripe API for you to try out with the API keys from your own Stripe account.","squadName":"","isBlacklisted":false,"isPrivateNetworkEntity":false,"isDomainNonTrivial":true,"privateNetworkMeta":"","isStale":false,"documentType":"workspace"}},{"score":277.04276,"normalizedScore":8.850476152472957,"document":{"watcherCount":1,"apiCount":0,"forkCount":0,"createdAt":"2024-12-30T20:31:12","publisherHandle":"security-specialist-4707142","reqSendCountExclCreator":22,"isstale":"false","id":"41734a2c-e67b-443f-a3f2-03f0506b7441","slug":"stripe-d","updatedAt":"2024-12-30T20:31:14","updatedBy":"40719756","entityType":"workspace","visibilityStatus":"public","squadId":"","tags":[],"isFSLinked":false,"forkLabel":"","publisherName":"Stripe","name":"Stripe D","dependencyCount":7,"collectionCount":3,"lastActivityTime":null,"warehouse__updated_at":"2026-04-24T13:00:00.000Z","privateNetworkFolders":[],"nameRaw":"Stripe D","reqSenderCountExclCreator":3,"isPublisherVerified":false,"publisherType":"user","curatedInList":[],"creatorId":"40719756","description":"👋 Introduction\nWelcome to the API development workspace. This workspace serves as a single source of truth for the APIs we build and helps new engineers get onboarded to our team's API landscape faster.\n🚀 Getting started with this workspace\nReference collections\nThese collections contain thorough documentation of our team's APIs. They will help you understand the capabilities of the services we own and how to use them effectively.\nAs an example, we've added the API Documentation collection. It contains requests and examples to create, read, update and delete collections via an API.\nSimilarly, we recommend adding #reference collections for your services to this workspace.\nBlueprint collections\nThese self-service collections curated by our team will help you observe workflows supported by the services we own. You can directly send requests using these endpoints.\nAs an example, we've added the RESTful API Basics collection that uses fake-store API to create, read, update and delete products.\nSimilarly, we recommend adding #blueprint collections for important workflows managed by your team.\nEnvironments\nEnvironments are set up to manage variables like base URLs, API keys, and tokens whose values you can change depending on the context of your work (e.g., development, staging, production).\n🛟 Help and support\nIf you have any questions or suggestions, please don't hesitate to reach out to your manager or any member of the Engineering team.","publisherId":"40719756","publisherLogo":"","isPublic":true,"categories":[],"views":0,"summary":"This workspace acts as a single source of truth for onboarding any engineer into your team.","squadName":"","isBlacklisted":false,"isPrivateNetworkEntity":false,"isDomainNonTrivial":false,"privateNetworkMeta":"","isStale":false,"documentType":"workspace"}},{"score":255.58519,"normalizedScore":11.403887401140215,"document":{"watcherCount":1,"apiCount":0,"forkCount":0,"createdAt":"2024-07-16T16:32:08","publisherHandle":"stripe-professional-services","reqSendCountExclCreator":16,"isstale":"false","id":"e44205e7-9c48-4c23-8f26-6b135353a883","slug":"stripe-apis","updatedAt":"2024-07-16T22:36:17","updatedBy":"36179241","entityType":"workspace","visibilityStatus":"public","squadId":"","tags":[],"isFSLinked":false,"forkLabel":"","publisherName":"Stripe Professional Services","name":"Stripe APIs","dependencyCount":3,"collectionCount":1,"lastActivityTime":null,"warehouse__updated_at":"2026-04-24T13:00:00.000Z","privateNetworkFolders":[],"nameRaw":"Stripe APIs","reqSenderCountExclCreator":6,"isPublisherVerified":false,"publisherType":"team","curatedInList":[],"creatorId":"36179241","description":"","publisherId":"6331168","publisherLogo":"https://res.cloudinary.com/postman/image/upload/t_team_logo/v1721166753/team/7bc5fad0ec7f29ab58879d38f7ac65f0cfe631852c724363fd73052ff2d77052.png","isPublic":true,"categories":[],"views":0,"summary":"This workspace contains resources that you can demo and share with customers and partners.","squadName":"","isBlacklisted":false,"isPrivateNetworkEntity":false,"isDomainNonTrivial":true,"privateNetworkMeta":"","isStale":false,"documentType":"workspace"}}],"api":[{"scor