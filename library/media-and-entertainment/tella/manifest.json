{
  "manifest_version": "0.3",
  "name": "tella-pp-mcp",
  "display_name": "Tella Public",
  "version": "4.2.1",
  "description": "Tella Public API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/tella-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/tella-pp-mcp",
      "args": [],
      "env": {
        "TELLA_API_KEY": "${user_config.tella_api_key}"
      }
    }
  },
  "user_config": {
    "tella_api_key": {
      "type": "string",
      "title": "TELLA_API_KEY",
      "description": "Sets TELLA_API_KEY for the Tella Public MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
