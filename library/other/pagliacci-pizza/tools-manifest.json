        {
          "name": "lastName",
          "type": "string",
          "location": "body",
          "description": "Last name",
          "required": true
        },
        {
          "name": "password",
          "type": "string",
          "location": "body",
          "description": "Password",
          "required": true
        },
        {
          "name": "phone",
          "type": "string",
          "location": "body",
          "description": "Phone"
        }
