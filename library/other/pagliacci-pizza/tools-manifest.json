      "name": "order-price_price-order",
      "description": "Price an order (requires API key)",
      "method": "POST",
      "path": "/OrderPrice",
      "params": [
        {
          "name": "ServiceType",
          "type": "string",
          "location": "body",
          "description": "Service type"
        },
        {
          "name": "StoreId",
          "type": "int",
          "location": "body",
          "description": "Store id"
        }
      ]
    },
