{
  "api_name": "allrecipes",
  "base_url": "https://www.allrecipes.com",
  "description": "Allrecipes Pocket — every Allrecipes recipe in your terminal: cached as data, with pantry-aware search, Bayesian-smoothed ranking, multi-recipe grocery lists, and clean markdown export.",
  "mcp_ready": "full",
  "http_transport": "browser-chrome",
  "auth": {
    "type": "none"
  },
  "required_headers": [],
  "tools": [
    {
      "name": "recipes_get",
      "description": "Fetch a recipe by ID + slug; returns parsed JSON-LD Recipe",
      "method": "GET",
      "path": "/recipe/{recipe_id}/{slug}/",
      "params": [
        {
          "name": "recipe_id",
          "type": "string",
          "location": "path",
          "description": "Numeric recipe ID (e.g. 9599)",
          "required": true
        },
        {
          "name": "slug",
          "type": "string",
          "location": "path",
          "description": "Recipe URL slug (e.g. quick-and-easy-brownies)",
          "required": true
        }
      ]
    },
    {
      "name": "recipes_search",
      "description": "Search Allrecipes for recipes matching a query",
      "method": "GET",
      "path": "/search",
      "params": [
        {
          "name": "q",
          "type": "string",
          "location": "query",
          "description": "Search query (e.g. 'brownies')",
          "required": true
        },
        {
          "name": "page",
          "type": "int",
          "location": "query",
          "description": "Result page (1-indexed; default 1)"
        }
      ]
    }
  ]
}
