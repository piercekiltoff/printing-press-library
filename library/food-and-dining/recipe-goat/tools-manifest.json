{
  "api_name": "recipe-goat",
  "base_url": "https://api.nal.usda.gov/fdc/v1",
  "description": "Recipe GOAT — find the best version of any recipe across 37 trusted sites, with offline cookbook, pantry match, substitution lookup, meal planning, and USDA-backed nutrition.",
  "mcp_ready": "full",
  "http_transport": "browser-chrome",
  "auth": {
    "type": "api_key",
    "header": "X-API-KEY",
    "in": "header",
    "env_vars": [
      "USDA_FDC_API_KEY"
    ]
  },
  "required_headers": [],
  "tools": [
    {
      "name": "foods_get",
      "description": "Get a specific food by FDC ID",
      "method": "GET",
      "path": "/food/{fdc_id}",
      "params": [
        {
          "name": "fdc_id",
          "type": "string",
          "location": "path",
          "description": "FoodData Central ID",
          "required": true
        },
        {
          "name": "nutrients",
          "type": "string",
          "location": "query",
          "description": "Comma-separated nutrient IDs to return"
        }
      ]
    },
    {
      "name": "foods_list",
      "description": "List foods paginated",
      "method": "GET",
      "path": "/foods/list",
      "params": [
        {
          "name": "pageSize",
          "type": "int",
          "location": "query",
          "description": "Results per page (1–200)"
        },
        {
          "name": "pageNumber",
          "type": "int",
          "location": "query",
          "description": "Page number (1-indexed)"
        },
        {
          "name": "dataType",
          "type": "string",
          "location": "query",
          "description": "Comma-separated list: Foundation,SR Legacy,Branded,Survey (FNDDS)"
        }
      ]
    },
    {
      "name": "foods_search",
      "description": "Search USDA FoodData Central for foods matching a query",
      "method": "GET",
      "path": "/foods/search",
      "params": [
        {
          "name": "query",
          "type": "string",
          "location": "query",
          "description": "Search term (e.g., 'chicken breast raw')",
          "required": true
        },
        {
          "name": "pageSize",
          "type": "int",
          "location": "query",
          "description": "Results per page (1–200)"
        },
        {
          "name": "pageNumber",
          "type": "int",
          "location": "query",
          "description": "Page number (1-indexed)"
        },
        {
          "name": "dataType",
          "type": "string",
          "location": "query",
          "description": "Comma-separated list: Foundation,SR Legacy,Branded,Survey (FNDDS)"
        }
      ]
    }
  ]
}
