{
  "manifest_version": "0.3",
  "name": "resend-pp-mcp",
  "display_name": "Resend",
  "version": "4.5.1",
  "description": "Resend API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/resend-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/resend-pp-mcp",
      "args": [],
      "env": {
        "RESEND_API_KEY": "${user_config.resend_api_key}"
      }
    }
  },
  "user_config": {
    "resend_api_key": {
      "type": "string",
      "title": "RESEND_API_KEY",
      "description": "Sets RESEND_API_KEY for the Resend MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
